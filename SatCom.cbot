/*
15 July 2026

ThreeSearch library program for Colobot Gold Edition. This library program is shared across all missions on the 9 planets, from Earth to Terranova.
For flying shooter bots, this library program used "ThreeSearch Progressive Caching Pattern" which is a masterpiece of optimization in game AI for pathfinding:
1. Lazy initialization (compute when needed)
2. Shared caching (all functions use same cache)
3. Passive preloading (cache during bots flight and bots crawl) 
4. Progressive speedup (gets faster with use)
5. Zero upfront cost (no pre-computation)

ThreeSearch Progressive Caching Pattern is a navigation architecture for terrain-based pathfinding that minimizes upfront preprocessing by combining lazy terrain evaluation, shared caching,
passive cache warming during normal movement, and progressive reuse of terrain knowledge across searches. The pattern is independent of the underlying pathfinding algorithm and can be paired with A*, bidirectional search, LiteRBS, Dijkstra, or other graph-search methods.

Usage:

1. Copy and paste following files from https://github.com/Three-Search/Colobot-Program to the Colobot\data\ai folder
SatCom.cbot
Grabber.cbot
Shooter.cbot
Builder.cbot

2. Load  the SatCom.cbot library program for each mission by editing the scene.txt file in the Colobot\data\levels\missions\chapterXXX\levelXXX folder and add LevelController script="SatCom.cbot" under BeginObject section.

For example, the scene.txt file for chapter003\level003 with title "On the Offensive" will look like the example below after adding LevelController script="SatCom.cbot" under BeginObject section:

BeginObject
LevelController script="SatCom.cbot"
CreateObject pos= 0.00; 0.00 dir=0.0 type=SpaceShip run=1

You can use PowerShell in Windows to add LevelController script="SatCom.cbot" to all scene.txt files. Copy and paste this script into PowerShell and run it.
$root='N:\Games\colobot\data\levels\missions'; Get-ChildItem $root -Recurse -Filter scene.txt | % { $c=Get-Content $_.FullName -Raw; $c=$c -replace 'BeginObject',"BeginObject`r`nLevelController script=`"SatCom.cbot`""; Set-Content $_.FullName $c -NoNewline }

3. In the bot Program Editor, declare an instance of the SatCom class, and you can call any function in the SatCom.cbot library program. For example:
extern void object::Tropica3()
{
	SatCom com();
	
	Message("Please start a program of Winged Grabber bot to call Mission() function of this bot");
	waitForAvailable(RepairCenter);
	
	Build(ResearchCenter);
	Build(BotFactory);
	Build(WingedShooter,"Mission()");
	
	go(SpaceShip);
	missionComplete();
	camerafocus(radar(WingedGrabber));
}

public void object::Mission()
{
	checkEnergyCell();
	
	if (category == WingedGrabber)
	{
		GrabMission();
	}
	else
	{
		ShootMission();
	}
}

*/

extern void object::houston()
{
	SatCom com();
}

public class Queue
{
	object[] items;
	int front;
	int rear;
	int length;
	object lockedBy;
	object station;
	
	// Constructor to initialize the queue
	public void Queue(int size)
	{
		for (int i = 0; i < size; i++)
		{
			items[i] = null;
		}
		front = 0;
		rear = 0;
		length = size;
		lockedBy = null;
		station = null;
	}
	
	// Method to acquire the lock
	synchronized void lock(object bot)
	{
		while (lockedBy != null)
		{
			// Wait until the lock is released
			wait(1);
		}
		lockedBy = bot;
	}
	
	// Method to release the lock
	void unlock()
	{
		lockedBy = null;
	}
	
	// Method to get the number of items in the queue
	int size()
	{
		if (rear >= front)
		{
			return rear - front;
		}
		else
		{
			return length - front + rear;
		}
	}
	
	// Method to add an item to the queue
	void enqueue(object item)
	{
		lock(item);
		if ((rear + 1) % length == front)
		{
			Message("Queue is full. Could not add object into queue");
			unlock();
			return;
		}
		items[rear] = item;
		rear = (rear + 1) % length;
		unlock();
	}
	
	// Method to remove an item from the queue
	object dequeue(object bot)
	{
		lock(bot);
		if (isEmpty())
		{
			Message("Queue is empty. Could not remove front object from queue");
			unlock();
			return null;
		}
		object item = items[front];
		items[front] = null; // Clear the spot
		front = (front + 1) % length;
		unlock();
		return item;
	}
	
	// Method to check if the queue is empty
	bool isEmpty()
	{
		return (front == rear);
	}
	
	// Method to peek at the front item of the queue without removing it
	object peek(object bot)
	{
		lock(bot);
		// Clean up null at the front of the queue before peeking
		if (front != rear && items[front] == null)
		{
			front = (front + 1) % length;
		}
		if (isEmpty())
		{
			Message("Queue is empty. Could not peek at the front object");
			unlock();
			return null;
		}
		unlock();
		return items[front];
	}
}

