public void object::avoidNearestObject(float m)
{
	int obj[];
	int i=0;
	obj[i++] = TitaniumOre;
	obj[i++] = UraniumOre;
	obj[i++] = Titanium;
	obj[i++] = PowerCell;
	obj[i++] = NuclearCell;
	obj[i++] = OrgaMatter;
	obj[i++] = TNT;
	obj[i++] = BlackBox;
	obj[i++] = KeyA;
	obj[i++] = KeyB;
	obj[i++] = KeyC;
	obj[i++] = KeyD;
	obj[i++] = WheeledGrabber;
	obj[i++] = TrackedGrabber;
	obj[i++] = WingedGrabber;
	obj[i++] = LeggedGrabber;
	obj[i++] = WheeledBuilder;
	obj[i++] = TrackedBuilder;
	obj[i++] = WingedBuilder;
	obj[i++] = LeggedBuilder;
	obj[i++] = WheeledShooter;
	obj[i++] = TrackedShooter;
	obj[i++] = WingedShooter;
	obj[i++] = LeggedShooter;
	obj[i++] = WheeledSniffer;
	obj[i++] = TrackedSniffer;
	obj[i++] = WingedSniffer;
	obj[i++] = LeggedSniffer;
	obj[i++] = WheeledOrgaShooter;
	obj[i++] = TrackedOrgaShooter;
	obj[i++] = WingedOrgaShooter;
	obj[i++] = LeggedOrgaShooter;
	obj[i++] = Subber;
	obj[i++] = Recycler;
	obj[i++] = Shielder;
	obj[i++] = Thumper;
	obj[i++] = PhazerShooter;
	obj[i++] = Me;
	
	object nearestObject = search(obj,this.position);
	if (nearestObject == null)
	{
		return;
	}
	
	float nearestDistance = distance2d(this.position,nearestObject.position);
	float directToObj = direction(nearestObject.position);
	int forwardOrBackward = -1;
	
	if (nearestDistance <= 1)
	{
		if (-15 <= directToObj || directToObj <= 15)
		{
			forwardOrBackward = -1;
			Message("Nearest Object right infront, move backward "+m*forwardOrBackward);
			move(m*forwardOrBackward);
		}
		
		if (-165 >= directToObj || directToObj >= 165)
		{
			forwardOrBackward = 1;
			Message("Nearest Object right behind, move forwards "+m*forwardOrBackward);
			move(m*forwardOrBackward);
		}
	}
}

public point[] object::flatSpacesAroundCenter(point p, float flatmin, float radius, int numPoints)
{
	float angleIncrement = 360 / numPoints;
	float angle;
	point pj,p1,p2;
	int i,j;
	point[] points;
	
	j = 0;
	
	for(i = 0; i < numPoints; i++)
	{
		angle = angleIncrement * i;
		p1.x = p.x + radius * cos(angle);
		p1.y = p.y + radius * sin(angle);
		p1.z = -1;
		p1.z = topo(p1);
		
		pj = flatspace(p1,flatmin,0,2,1);
		
		if (topo(pj) >= 0 && flatground(pj,flatmin) >= (flatmin - 0.2))
		{
			if (j == 0)
			{
				points[j] = pj;
				j++;
			}
			else
			{
				if (distance2d(pj,points[j-1]) > 9)
				{
					points[j] = pj;
					j++;
				}
			}
		}
	}
	
	for(i = 0; i < numPoints; i++)
	{
		angle = angleIncrement * i;
		p2.x = p.x + (radius + 12) * cos(angle);
		p2.y = p.y + (radius + 12) * sin(angle);
		p2.z = -1;
		p2.z = topo(p2);
		
		pj = flatspace(p2,flatmin,0,2,1);
		
		if (topo(pj) >= 0 && flatground(pj,flatmin) >= (flatmin - 0.2))
		{
			if (j == 0)
			{
				points[j] = pj;
				j++;
			}
			else
			{
				if (distance2d(pj,points[j-1]) > 9)
				{
					points[j] = pj;
					j++;
				}
			}
		}
	}
	return points;
}

public point object::flatSpace()
{
	SatCom com();
	com.returnMessage = category+": flatSpace() start";
	com.returnCode = 1;
	
	point p;
	point empty(nan,nan,nan);
	
	if (com.nextPoint < sizeof(com.pointsAroundShip))
	{
		p = com.pointsAroundShip[com.nextPoint];
		com.nextPoint = com.nextPoint + 1;
		com.returnCode = 0;
		return p;
	}
	else
	{
		Message("No flat space found in designated area");
		com.returnCode = 1;
	}
	return empty;
}

public point object::getSpaceOnShip()
{
	object sp = radar(SpaceShip);
	
	//This basically creates a list of objects that can be on the ship
	int obj[];
	int i=0;
	obj[i++] = TitaniumOre;
	obj[i++] = UraniumOre;
	obj[i++] = Titanium;
	obj[i++] = PowerCell;
	obj[i++] = NuclearCell;
	obj[i++] = OrgaMatter;
	obj[i++] = TNT;
	obj[i++] = BlackBox;
	obj[i++] = KeyA;
	obj[i++] = KeyB;
	obj[i++] = KeyC;
	obj[i++] = KeyD;
	obj[i++] = WheeledGrabber;
	obj[i++] = TrackedGrabber;
	obj[i++] = WingedGrabber;
	obj[i++] = LeggedGrabber;
	obj[i++] = WheeledBuilder;
	obj[i++] = TrackedBuilder;
	obj[i++] = WingedBuilder;
	obj[i++] = LeggedBuilder;
	obj[i++] = WheeledShooter;
	obj[i++] = TrackedShooter;
	obj[i++] = WingedShooter;
	obj[i++] = LeggedShooter;
	obj[i++] = WheeledSniffer;
	obj[i++] = TrackedSniffer;
	obj[i++] = WingedSniffer;
	obj[i++] = LeggedSniffer;
	obj[i++] = WheeledOrgaShooter;
	obj[i++] = TrackedOrgaShooter;
	obj[i++] = WingedOrgaShooter;
	obj[i++] = LeggedOrgaShooter;
	obj[i++] = Subber;
	obj[i++] = Recycler;
	obj[i++] = Shielder;
	obj[i++] = Thumper;
	obj[i++] = PhazerShooter;
	obj[i++] = Me;
	
	//This section specifies free spots on the ship (you know, the squares)
	point[] spaces;
	
	spaces[0].x = sp.position.x - 3.5;
	spaces[0].y = sp.position.y - 3.5;
	spaces[0].z = sp.position.z + 7.5;
	
	spaces[1].x = sp.position.x - 3.5;
	spaces[1].y = sp.position.y;
	spaces[1].z = sp.position.z + 7.5;
	
	spaces[2].x = sp.position.x - 3.5;
	spaces[2].y = sp.position.y + 3.5;
	spaces[2].z = sp.position.z + 7.5;
	
	spaces[3].x = sp.position.x;
	spaces[3].y = sp.position.y - 3.5;
	spaces[3].z = sp.position.z + 7.5;
	
	spaces[4].x = sp.position.x;
	spaces[4].y = sp.position.y + 3.5;
	spaces[4].z = sp.position.z + 7.5;
	
	spaces[5].x = sp.position.x + 3.5;
	spaces[5].y = sp.position.y - 3.5;
	spaces[5].z = sp.position.z + 7.5;
	
	spaces[6].x = sp.position.x + 3.5;
	spaces[6].y = sp.position.y;
	spaces[6].z = sp.position.z + 7.5;
	
	spaces[7].x = sp.position.x + 3.5;
	spaces[7].y = sp.position.y + 3.5;
	spaces[7].z = sp.position.z + 7.5;
	
	object item;
	
	//We check if any of these is free by checking if any of listed objects is located in 2.5m radius
	for (i = 0; i < 8; i++)
	{
		item = search(obj, spaces[i]);
		if (distance2d(item.position, spaces[i]) > 2.5)
		{
			return spaces[i];
		}
	}
	
	//If all of them are taken, we return a point -1337, -1337
	point empty(nan,nan,nan);
	return empty;
}

public void object::Builder()
{
	SatCom com();
	point p;
	int c;
	object shooter,grabber;
	
	wait(5);
	
	for (int i = 0; i < com.maxBuild; i++)
	{
		if (energyCell.energyLevel < 0.3)
		{
			p = position;
			chargeCell();
			go(p);
		}
		
		Message("Wait to build next object");
		while (!com.builderInUsed)
		{
			if (distance2Enemies(this.position) <= com.safeAnt)
			{
				go(space(position,20,40,4));
				if (distance2d(position,location(SpaceShip)) < 25)
				{
					go(space(location(SpaceShip),35,60,4));
				}
			}
			wait(2);
		}
		
		shooter = radar(WingedOrgaShooter);
		if (shooter == null)
		{
			shooter = radar(WingedShooter);
		}
		if (shooter == null)
		{
			shooter = radar(LeggedOrgaShooter);
		}
		if (shooter == null)
		{
			shooter = radar(LeggedShooter);
		}
		if (shooter == null && com.builderCameraFocus)
		{
			camerafocus(this);
		}
		
		p = com.buildPoint;
		c = com.buildCategory;
		Message("Building "+catName(c));
		
		if ((c == BotFactory || c == NuclearPlant || c == PowerStation || c == RepairCenter) && distance2d(p,location(SpaceShip)) < 30)
		{
			go(awayShipPoint(p));
		}
		
		while (search(com.ALL_BOTS,p,0,8) != null)
		{
			wait(5);
		}
		go(p);
		build(c);
		
		if (shooter == null && com.builderCameraFocus)
		{
			grabber = radar(LeggedGrabber);
			if (grabber == null)
			{
				grabber = radar(WheeledGrabber);
			}
			if (grabber == null)
			{
				grabber = radar(WingedGrabber);
			}
			if (grabber != null)
			{
				camerafocus(grabber);
			}
		}
		
		com.builderInUsed = false;
		
		if (c == BotFactory || c == NuclearPlant)
		{
			go(space(location(SpaceShip),35,60,10));
		}
		else
		{
			go(space(p,20,40,4));
		}
		
		if (distance2d(position,location(SpaceShip)) < 25)
		{
			go(space(location(SpaceShip),35,60,10));
		}
	}
	go(space(location(SpaceShip),35,60,10));
	missionComplete();
}

public void object::Build(int c, point p)
{
	SatCom com();
	point buildPoint;
	
	if (search(Titanium,p,0,1) == null)
	{
		moveObjToPlace(Titanium,p);
		buildPoint = location(Titanium);
	}
	else
	{
		buildPoint = p;
	}
	
	while (com.builderInUsed)
	{
		wait(5);
	}
	
	if (!found(com.builderBotCategory))
	{
		produce(space(p,5,10,1),0,com.builderBotCategory,"Builder.cbot",100);
		turn(direction(p));
	}
	
	com.buildPoint = buildPoint;
	com.buildCategory = c;
	com.builderInUsed = true;
}

public void object::Build(int c)
{
	goGrab(Titanium);
	moveObjToPlace(Titanium,flatSpace());
	Build(c,location(Titanium));
}

public void object::Build(int c, string s)
{
	goGrab(Titanium);
	
	waitForAvailable(BotFactory);
	moveObjToObj(Titanium,BotFactory);
	
	if (c == TrackedGrabber)
	{
		waitForResearch(ResearchTracked);
	}
	else if (c == WingedGrabber)
	{
		waitForResearch(ResearchWinged);
	}
	else if (c == LeggedGrabber)
	{
		waitForResearch(ResearchLegged);
	}
	else if (c == TrackedBuilder)
	{
		waitForResearch(ResearchBuilder);
	}
	
	Message("Building "+catName(c));
	factory(c,initProgram(s));
}

public float object::minSafeDistance(object o)
{
	float safedis = 25;
	
	if (o == null)
	{
		safedis = 0;
	}
	else
	{
		switch (o.category)
		{
			case GraviPlant: safedis = 25; break;
			case AlienAnt: safedis = 50; break;
			case AlienSpider: safedis = 50; break;
			case AlienWorm: safedis = 50; break;
			case AlienEgg: safedis = 50; break;
			case AlienWasp: safedis = 50; break;
			default: safedis = 10;
		}
	}
	
	return safedis;
}

public bool object::nearObstacles(point c)
{
	SatCom com();
	
	object nearestObstacle;
	nearestObstacle = search(com.obstacles,c);
	
	if (nearestObstacle == null)
	{
		return false;
	}
	
	if (distance2d(c, nearestObstacle.position) < 6)
	{
		return true;
	}
	return false;
}

public point object::randomFreePoint(point center, float minDistance, float maxDistance)
{
	point randomPoint = space(center,minDistance,maxDistance,4);
	int maxAttempts = 100; // Limit the number of attempts to find a free point
	
	for (int i = 0; i < maxAttempts; i++)
	{
		// Generate a random distance within the specified range
		float distance = minDistance + (maxDistance - minDistance) * rand();
		// Generate a random angle
		float angle = 360 * rand();
		
		// Calculate random X and Y coordinates based on the distance and angle
		float x = center.x + distance * cos(angle);
		float y = center.y + distance * sin(angle);
		
		// Set the Z coordinate using the terrain height
		randomPoint.x = x;
		randomPoint.y = y;
		randomPoint.z = topo(randomPoint);
		
		// Check if the point is free
		if (isFreePoint(randomPoint))
		{
			return randomPoint; // Return the first free point found
		}
	}
	return space(center,minDistance,maxDistance,4);
}

public bool object::isFreePoint(point p)
{
	// Check for obstacles or other objects at the point
	if (category == WheeledGrabber && distance2SpaceShip(p) < 20)
	{
		return false;
	}
	
	if (flatground(p,2) < 0.5)
	{
		return false;
	}
	
	object nearbyObject = search(Any,p,0,2);
	if (nearbyObject != null)
	{
		return false;
	}
	return true;
}

public point object::freePoint(point c)
{
	return freePoint(c,6,36);
}

public point object::freePoint(point c, float radius, int numPoints)
{
	SatCom com();
	
	int i,j;
	
	float maxDistance = -1.0;
	float distanceToObstacle;
	object nearestObstacle;
	point farthestPointToObstacle;
	point p;
	bool foundFreePoint;
	float angleIncrement = 360 / numPoints;
	float angle;
	
	nearestObstacle = search(com.obstacles,c);
	if (nearestObstacle == null)
	{
		p.x = c.x;
		p.y = c.y;
		p.z = topo(c);
		return p;
	}
	
	if (distance2d(c, nearestObstacle.position) > radius)
	{
		p.x = c.x;
		p.y = c.y;
		p.z = topo(c);
		return p;
	}
	
	j = 0;
	foundFreePoint = false;
	for(i = 0; i < numPoints; i++)
	{
		angle = angleIncrement * i;
		p.x = c.x + radius * cos(angle);
		p.y = c.y + radius * sin(angle);
		p.z = topo(p);
		nearestObstacle = search(com.obstacles,p);
		distanceToObstacle = distance2d(p, nearestObstacle.position);
		if (distanceToObstacle > maxDistance && p.z > 1.5)
		{
			foundFreePoint = true;
			maxDistance = distanceToObstacle;
			j = i;
			farthestPointToObstacle.x = p.x;
			farthestPointToObstacle.y = p.y;
			farthestPointToObstacle.z = p.z;
		}
	}
	if (foundFreePoint)
	{
		return farthestPointToObstacle;
	}
	else
	{
		Message("Exception, not found freePoint");
		p.x = c.x;
		p.y = c.y;
		p.z = topo(c);
		return p;
	}
}

public point object::gunPoint(float d)
{
	point p;
	if (category == WingedShooter || category == WingedOrgaShooter)
	{
		p = aheadPoint(d);
		p.z = this.position.z + d;
		return p;
	}
	p.x = this.position.x + d * cos(this.pitch) * cos(this.orientation);
	p.y = this.position.y + d * cos(this.pitch) * sin(this.orientation);
	p.z = this.position.z + d * sin(this.pitch);
	if (topo(p) >= topo(this.position))
	{
		p.z = this.position.z + d;
	}
	return p;
}

public point object::gunPoint()
{
	return gunPoint(1.5);
}

public point object::aheadPoint(object o, float d, float angle)
{
	point h;
	h.x = o.position.x + d*cos(o.orientation + angle);
	h.y = o.position.y + d*sin(o.orientation + angle);
	h.z = o.position.z;
	return h;
}

public point object::aheadPoint(float d, float angle)
{
	point h;
	h = aheadPoint(this, d, angle);
	return h;
}

public point object::aheadPoint(float d)
{
	point h;
	h = aheadPoint(d, 0);
	return h;
}

public point object::behindPoint(float d)
{
	point h;
	h = aheadPoint(d, 180);
	return h;
}

public point object::aheadPoint(object o, float d)
{
	point h;
	h = aheadPoint(o, d, 0);
	return h;
}

public point object::behindPoint(object o, float d)
{
	point h;
	h = aheadPoint(o, d, 180);
	return h;
}

public point object::leftPoint(point p1)
{
	point p2,p3;
	float d = 1;
	p2 = this.position;
	p3.x = p2.x - d*(p1.y - p2.y);
	p3.y = p2.y + d*(p1.x - p2.x);
	p3.z = this.position.z;
	return p3;
}

public point object::leftPoint(point p1, point p2)
{
	point p3;
	float d = 1;
	p3.x = p2.x - d*(p1.y - p2.y);
	p3.y = p2.y + d*(p1.x - p2.x);
	p3.z = this.position.z;
	return p3;
}

public point object::leftPoint(float d)
{
	point ahead,left;
	
	ahead = aheadPoint(d);
	left = leftPoint(ahead,this.position);
	return left;
}

public point object::rightPoint(point p1)
{
	point p2,p3;
	float d = 1;
	p2 = this.position;
	p3.x = p2.x + d*(p1.y - p2.y);
	p3.y = p2.y - d*(p1.x - p2.x);
	p3.z = this.position.z;
	return p3;
}

public point object::rightPoint(point p1, point p2)
{
	point p3;
	float d = 1;
	p3.x = p2.x + d*(p1.y - p2.y);
	p3.y = p2.y - d*(p1.x - p2.x);
	p3.z = this.position.z;
	return p3;
}

public point object::rightPoint(float d)
{
	point ahead,right;
	
	ahead = aheadPoint(d);
	right = rightPoint(ahead,this.position);
	return right;
}

// Function to find the left point P3 given P1 and P2
public point object::leftPoint(point p1, point p2, float dis)
{
	// Calculate the vector components from P1 to P2
	float dx = p2.x - p1.x;
	float dy = p2.y - p1.y;
	
	// Calculate the length of the vector P1P2
	float length = distance2d(p1, p2);
	
	// Calculate the normalized perpendicular vectors
	float perp1x = (dy / length) * dis;
	float perp1y = (-dx / length) * dis;
	float perp2x = (-dy / length) * dis;
	float perp2y = (dx / length) * dis;
	
	// Calculate the two possible coordinates for P3
	point p3_1(p2.x + perp1x, p2.y + perp1y,0);
	point p3_2(p2.x + perp2x, p2.y + perp2y,0);
	
	p3_1.z = topo(p3_1);
	p3_2.z = topo(p3_2);
	
	// Determine the left point
	if ((dx * perp1y - dy * perp1x) > 0)
	{
		return p3_1;
	}
	else
	{
		return p3_2;
	}
}

// Function to find the right point P3 given P1 and P2
public point object::rightPoint(point p1, point p2, float dis)
{
	// Calculate the vector components from P1 to P2
	float dx = p2.x - p1.x;
	float dy = p2.y - p1.y;
	
	// Calculate the length of the vector P1P2
	float length = distance2d(p1, p2);
	
	// Calculate the normalized perpendicular vectors
	float perp1x = (dy / length) * dis;
	float perp1y = (-dx / length) * dis;
	float perp2x = (-dy / length) * dis;
	float perp2y = (dx / length) * dis;
	
	// Calculate the two possible coordinates for P3
	point p3_1(p2.x + perp1x, p2.y + perp1y,0);
	point p3_2(p2.x + perp2x, p2.y + perp2y,0);
	
	p3_1.z = topo(p3_1);
	p3_2.z = topo(p3_2);
	
	// Determine the right point
	if ((dx * perp1y - dy * perp1x) > 0)
	{
		return p3_2;
	}
	else
	{
		return p3_1;
	}
}

public point object::sensor(float d, point target)
{
	SatCom com();
	
	int i;
	int n = 5;
	point hit,p;
	point sensorPoints[n];
	
	// if hit.z = 0 no sensor point hit mountain
	hit.x = 0;
	hit.y = 0;
	hit.z = 0;
	
	sensorPoints[0] = aheadPoint(d);
	sensorPoints[1] = aheadPoint(d,45);
	sensorPoints[2] = aheadPoint(d,-45);
	sensorPoints[3] = aheadPoint(d,90);
	sensorPoints[4] = aheadPoint(d,-90);
	
	for (i = 0; i < n; i++)
	{
		p = sensorPoints[i];
		p.z = topo(p);
		if (p.z >= this.position.z + 1)
		{
			hit = p;
			break;
		}
	}
	return hit;
}

public void object::moveAndDestroy(object target)
{
	SatCom com();
	
	object enemies[],o;
	float dir;	// direction of target from shooter
	float dis;	// distance of target from shooter
	float dif;	// difference in altitude of target & shooter (relative to sea-level)
	float ang;	// angle shooter must aim (-20 degrees favorable)
	int i;
	point p,hit,left,right,behind;
	bool los = false;
	
	if (target == null) return;
	fly(target.position);
	
	if (com.detectedGraviPlant)
	{
		o = radar(com.roots,0,180,0,3);
		if (o != null)
		{
			if (distance(this.position,o.position) <= 3)
			{
				Message("Near to AlienRoot");
				//turn(direction(o.position));
				while (distance2d(this.position,o.position) <= 6)
				{
					motor(-1,-1);
					jet(0.2);
					if  (radar(com.roots,180,90,0,3) != null)
					{
						motor(0,0);
						jet(1);
						break;
					}
				}
			}
		}
	}
	
	if (target == null) return;
	dis = distance2d(this.position,target.position);
	if (dis > com.attackRange)
	{
		if (category == WingedShooter || category == WingedOrgaShooter)
		{
			hit = sensor(1.5,target.position);
			if (hit.z > 0)
			{
				motor(-0.1,-0.1);
				escapeMountain(this.position,target.position);
			}
		}
	}
	else // if within range
	{
		if (!checkLOS(target))
		{
			los = false;
			for (i = 1; i < 10; i++)
			{
				left = leftPoint(5*i);
				left.z = this.position.z;
				if (checkLOS(left,target.position) && topo(left) < left.z)
				{
					p = left;
					los = true;
					break;
				}
				right = rightPoint(5*i);
				right.z = this.position.z;
				if (checkLOS(right,target.position) && topo(right) < right.z)
				{
					p = right;
					los = true;
					break;
				}
			}
			if (category == WingedShooter || category == WingedOrgaShooter)
			{
				if (los)
				{
					// Found new position with LOS, fly to that position and continue attack
					fly2p(p);
				}
				else
				{
					// Could not find new position with LOS, fly to side with lower topo and return to try again. 
					if (topo(left) < topo(right))
					{
						Message("No LOS, fly to left side");
						fly2p(left);
					}
					else
					{
						Message("No LOS, fly to right side");
						fly2p(right);
					}
					return;
				}
			}
			else
			{
				if (los)
				{
					// Found new position with LOS,  crawl to that position and continue attack
					go(p);
				}
				else
				{
					// Could not find new position with LOS, crawl direct to target and return to try again
					crawl(target.position);
					return;
				}
			}
		}
		motor(0,0);
		aimAndFire(target);
	}
}

public void object::aimAndFire(object target)
{
	SatCom com();
	float dir,angle,dis,dif,jetPower;
	int i;
	float z;
	float time;
	
	if (target == null || target.dead)
	{
		return;
	}
	
	if (category == PhazerShooter)
	{
		PhazerAim(target);
		return;
	}
	
	if (category == WheeledShooter || category == TrackedShooter || category == LeggedShooter || category == WheeledOrgaShooter || category == TrackedOrgaShooter || category == LeggedOrgaShooter)
	{
		LandAim(target);
		return;
	}
	
	if (category == WingedShooter || category == WingedOrgaShooter)
	{
		AirAim(target);
		return;
	}
}

public bool object::checkLOS(object target)
{
	return checkLOS(gunPoint(),target.position);
}

public bool object::checkLOS(point target)
{
	return checkLOS(gunPoint(),target);
}

public bool object::checkLOS(point bot_position, point ant_position)
{
	SatCom com();
	
	if (!com.checkLOS || com.detectedWorm || category == PhazerShooter)
	{
		return true;
	}
	
	float total_distance = distance(bot_position, ant_position);
	
	//if (total_distance < 2)
	//{
	//	return true;
	//}
	
	// Calculate the direction vector from the bot to the ant
	float dx = (ant_position.x - bot_position.x) / total_distance;
	float dy = (ant_position.y - bot_position.y) / total_distance;
	float dz = (ant_position.z - bot_position.z) / total_distance;
	float clearance = (category == WingedOrgaShooter || category == LeggedOrgaShooter) ? 0.5 : 0.2;
	//float end = total_distance - ((category == WingedOrgaShooter || category == LeggedOrgaShooter) ? 2.0 : 1.0);
	float end = total_distance;
	//if (end < 2)
	//{
	//	return true;
	//}
	
	point p;
	
	// Loop through every 0.5 meter from bot position to ant position
	for (float t = 2.0; t < end; t += 0.5)
	{
		p.x = bot_position.x + dx * t;
		p.y = bot_position.y + dy * t;
		p.z = bot_position.z + dz * t;
		if (topo(p) > p.z + clearance) return false;
	}
	return true;
}

public void object::gotoSafeLZ()
{
	gotoSafeLZ(this);
}

public bool object::isFlat(point p, float radius)
{
	// Check 4 neighbor points: up, right, down, left
	// Each at distance 'radius' from point p
	
	// Directions: up, right, down, left
	float dirX[] = {0, 1, 0, -1};
	float dirY[] = {1, 0, -1, 0};
	
	for (int i = 0; i < 4; i++)
	{
		point neighbor;
		neighbor.x = p.x + dirX[i] * radius;
		neighbor.y = p.y + dirY[i] * radius;
		neighbor.z = topo(neighbor);
		
		// If height difference > 0.4m, terrain is not flat
		if (abs(neighbor.z - p.z) > 0.4) return false;
	}
	
	// All 4 neighbors are within 0.4m height difference
	return true;
}

public bool object::isLandingPoint(point p)
{
	SatCom com();
	
	if (!isFlat(p,com.safeFlatGround)) return false;
	if (distance2GraviPlant(p) < com.safeRoot) return false;
	//if (distance2Enemies(p) < com.safeAnt*3/2) return false;
	if (!checkLOS(p)) return false;
	return true;
}

public point object::searchSafeLZ(point botPos)
{
	SatCom com();
	
	int botIdx = getNodeIndex(botPos);
	int botX = botIdx % com.gridSize;
	int botY = botIdx / com.gridSize;
	
	for (int radius = 1; radius <= 15; radius++)
	{
		int nodesOnSquare = radius * 8;
		
		for (int i = 0; i < nodesOnSquare; i++)
		{
			int dx, dy;
			
			if (i < radius * 2)
			{
				dx = -radius + i;
				dy = -radius;
			}
			else if (i < radius * 4)
			{
				dx = radius;
				dy = -radius + (i - radius * 2);
			}
			else if (i < radius * 6)
			{
				dx = radius - (i - radius * 4) - 1;
				dy = radius;
			}
			else
			{
				dx = -radius;
				dy = radius - (i - radius * 6) - 1;
			}
			
			int gridX = botX + dx;
			int gridY = botY + dy;
			
			if (gridX < 0 || gridX >= com.gridSize || gridY < 0 || gridY >= com.gridSize) continue;
			
			int idx = gridY * com.gridSize + gridX;
			
			// === CANDIDATE CHECK ===
			float candidateZ = getNodeZ(idx);
			if (candidateZ < com.safeTopo) continue;
			if (candidateZ > botPos.z + 2.5) continue;
			
			point center;
			center.x = getNodeX(idx);
			center.y = getNodeY(idx);
			center.z = candidateZ;
			
			if (isLandingPoint(center))
			{
				return center;
			}
			
			// === 4 MIDPOINTS (sqrt(50) ˜ 7.07m) ===
			float radius_mid = 7.07;
			float dirX[] = {1, 1, -1, -1};
			float dirY[] = {1, -1, -1, 1};
			
			for (int d = 0; d < 4; d++)
			{
				point p;
				p.x = center.x + dirX[d] * radius_mid;
				p.y = center.y + dirY[d] * radius_mid;
				p.z = topo(p);
				
				if (p.z < com.safeTopo) continue;
				if (p.z > botPos.z + 2.5) continue;
				
				if (isLandingPoint(p))
				{
					return p;
				}
			}
		}
	}
	
	point empty;
	empty.x = 0;
	empty.y = 0;
	empty.z = 0;
	return empty;
}

public void object::gotoSafeLZ(object o)
{
	SatCom com();
	
	float t = abstime();
	point landingPoint = searchSafeLZ(this.position);
	if (landingPoint.x == 0 && landingPoint.y == 0 && landingPoint.z == 0)
	{
		Message("Could not found safe landing point! Emergency landing at current position.");
		landingPoint = this.position;
		landingPoint.z = topo(landingPoint);
	}
	com.returnMessage = "Found safe landing point at " + distance2d(this.position,landingPoint) + " m, elapsed time "+(abstime() - t) +" second(s)";
	landAndRest(landingPoint);
}

public float object::speed(point p)
{
	float botTopo, pTopo, speed = 0;
	
	botTopo = topo(this.position);
	pTopo = topo(p);
	
	if (botTopo - pTopo > 0.5)
	{
		speed = 1;
	}
	else if (0.1 < botTopo - pTopo && botTopo - pTopo < 0.5)
	{
		speed = 0.5;
	}
	else if (pTopo - botTopo > 0.5)
	{
		speed = -1;
	}
	else if (0.1 < pTopo - botTopo && pTopo - botTopo < 0.5)
	{
		speed = -0.5;
	}
	else
	{
		speed = 0;
	}
	
	return speed;
}

public void object::checkEnemyWhenInLoop()
{
	SatCom com();
	
	object enemy = radar(com.ants,0,360,0,com.attackRange);
	com.returnMessage = "checkEnemyWhenInLoop";
	if (enemy != null)
	{
		if (!checkLOS(enemy.position)) return;
		Message("Enemy detected! Attacking...");
		float dir = direction(enemy.position);
		// Normalize the angle
		if (dir > 180)
		{
			dir -= 360;
		}
		else if (dir < -180)
		{
			dir += 360;
		}
		turn(dir);
		aimAndFire(enemy);
	}
}

public void object::landAndRest(point p)
{
	SatCom com();
	
	object enemy;
	point ahead,behind,left,right;
	float d = 1.5;
	float dir;
	int i;
	
	plantFlag(p,52); // Yellow Circle
	
	fly2p(p);
	while (this.temperature > 0)
	{
		while (this.altitude > 0 && this.temperature > 0)
		{
			jet(-0.8);
		}
		// check if rest on slope
		if (this.altitude < 0.5 && flatground(this.position,0.1) < 0.1)
		{
			ahead = aheadPoint(d*4);
			if (topo(ahead) < this.position.z)
			{
				motor(-0.05,-0.05);
			}
			else
			{
				behind = behindPoint(d);
				left = leftPoint(this.position,behind);
				right = rightPoint(this.position,behind);
				motor(speed(left),speed(right));
			}
		}
		checkEnemyWhenInLoop();
	}
}

public point object::getRestPoint(object center, float radius)
{
	SatCom com();
	point p,bestPoint,flatSpaces[];
	float dis,minDis;
	
	if (center.category == SpaceShip)
	{
		flatSpaces = com.pointsAroundShip;
	}
	else
	{
		flatSpaces = flatSpacesAroundCenter(center.position,1,radius,36);
	}
	
	minDis = 999999;
	for (int i = 0; i < sizeof(flatSpaces); i++)
	{
		p = flatSpaces[i];
		if (isFreePoint(p))
		{
			dis = distance2d(this.position,p);
			if (dis < minDis)
			{
				bestPoint = p;
				minDis = dis;
			}
		}
	}
	
	return bestPoint;
}

public void object::checkSelfStatus()
{
	SatCom com();
	
	if (this.temperature > com.temperatureThreshold)
	{
		aim(0,0);
		gotoSafeLZ();
	}
	
	if (this.energyCell.energyLevel < com.energyThreshold)
	{
		aim(0,0);
		chargeCell();
		if (this.shieldLevel < com.shieldThreshold)
		{
			repair();
		}
	}
	
	if (this.shieldLevel < com.shieldThreshold)
	{
		aim(0,0);
		repair();
		if (this.energyCell.energyLevel < com.energyThreshold)
		{
			chargeCell();
		}
	}
}

public void object::checkSelfStatus(object target)
{
	SatCom com();
	
	if (this.temperature > com.temperatureThreshold)
	{
		aim(0,0);
		gotoSafeLZ(target);
	}
	
	if (this.energyCell.energyLevel < com.energyThreshold)
	{
		aim(0,0);
		chargeCell();
		if (this.shieldLevel < com.shieldThreshold)
		{
			repair();
		}
	}
	
	if (this.shieldLevel < com.shieldThreshold)
	{
		aim(0,0);
		repair();
		if (this.energyCell.energyLevel < com.energyThreshold)
		{
			chargeCell();
		}
	}
}

public void object::checkSelfStatus(object center, float radius)
{
	SatCom com();
	
	point restPoint;
	
	if (this.temperature > com.temperatureThreshold)
	{
		aim(0,0);
		if (center == null)
		{
			gotoSafeLZ();
		}
		else
		{
			if (center.category == SpaceShip)
			{
				restPoint = getRestPoint(center,radius/2);
				landAndRest(restPoint);
			}
			else
			{
				gotoSafeLZ(center);
			}
		}
	}
	
	if (this.energyCell.energyLevel < com.energyThreshold)
	{
		aim(0,0);
		chargeCell();
		if (this.shieldLevel < com.shieldThreshold)
		{
			repair();
		}
	}
	
	if (this.shieldLevel < com.shieldThreshold)
	{
		aim(0,0);
		if (com.repairQueue.isEmpty())
		{
			repair();
			if (this.energyCell.energyLevel < com.energyThreshold)
			{
				chargeCell();
			}
		}
	}
}

public void object::serviceTowers()
{
	SatCom com();
	
	object towers[],o;
	point p;
	bool lowEnergy;
	
	p = flatspace(location(PowerStation),0.5,15,25,1);
	
	chargeCell();
	go(p);
	
	towers = radarall(DefenseTower);
	lowEnergy = false;
	while (true)
	{
		if (lowEnergy)
		{
			chargeCell();
			go(p);
		}
		else
		{
			wait(5);
		}
		
		towers = radarall(DefenseTower);
		lowEnergy = false;
		for (int i = 0; i < sizeof(towers); i++)
		{
			o = towers[i];
			if (o.energyCell != null && o.energyCell.energyLevel < com.energyThreshold)
			{
				go(o);
				while (distance2Wasp(position) < com.safeAnt)
				{
					wait(2);
				}
				switchCell();
				lowEnergy = true;
				break;
			}
		}
	}
}

public void object::attack()
{
	SatCom com();
	
	while (com.cachedNodes < 0)
	{
		wait(0.2);
	}
	
	if (category == WingedShooter || category == WingedOrgaShooter)
	{
		airAttack();
	}
	else
	{
		landAttack();
	}
}

public void object::airAttack()
{
	airAttack(this,10000);
}

public void object::airAttack(object o,float radius)
{
	errmode(0);
	SatCom com();
	object enemy,root,center;
	float dir,dis2Base,dis2Enemy,detectRange;
	point p,last,start,left,right;
	int i;
	
	ipf(10000);
	
	center = o;
	detectRange = radius;
	
	i = 0;
	last = this.position;
	while (true)
	{
		checkSelfStatus();
		
		if (com.detectedEgg && !com.detectedWasp)
		{
			if (radar(AlienWasp) != null)
			{
				com.detectedWasp = true;
			}
		}
		enemy = search(com.ants,center.position,0,detectRange);
		if (enemy == null && com.detectedWasp)
		{
			enemy = search(AlienWasp,center.position,0,detectRange);
		}
		else if (enemy == null && com.detectedWorm)
		{
			enemy = Radar(AlienWorm);
		}
		
		if (enemy != null)
		{
			if (enemy.category == AlienWorm && topo(enemy.position) < 0)
			{
				Message("Target is underwater, wait for next target");
				continue;
			}
			
			if (com.detectedGraviPlant)
			{
				root = search(GraviPlant,enemy.position,0,com.attackRange);
				if (root != null)
				{
					if (distance2d(this.position,root.position) > com.safeAnt && distance2d(this.position,root.position) < distance2d(this.position,enemy.position))
					{
						left = leftPoint(10);
						right = rightPoint(10);
						left.z = this.position.z;
						right.z = this.position.z;
						if (distance2d(left,enemy.position) < distance2d(right,enemy.position))
						{
							p = left;
						}
						else
						{
							p = right;
						}
						fly(p);
						wait(1);
						continue;
					}
				}
			}
			
			// check how near to Ant
			if (distance2Ant(this.position) <= com.safeAnt)
			{
				// too near to enemy, update enemy
				enemy = radar(com.ants);
			}
			
			i++;
			moveAndDestroy(enemy);
			if (isStuck(last))
			{
				if (i > 10)
				{
					Message("Avoiding obstacle");
					motor(0,0);
					jet(1);
					wait(1);
					motor(-1,-1);
					wait(1);
					turn(45);
					motor(1,1);
					wait(1);
					i = 0;
					last = this.position;
				}
			}
			else
			{
				i = 0;
				last = this.position;
			}
		}
		else
		{
			break;
		}
	}
	
	gotoSafeLZ();
	missionComplete();
	errmode(1);
}

public void object::airGuard(object center, float radius)
{
	errmode(0);
	SatCom com();
	object enemy,root;
	float dir,dis2Base,dis2Enemy,detectRange;
	point p,last,start,left,right;
	int i;
	
	ipf(10000);
	
	if (center == null)
	{
		attack();
		return;
	}
	
	start = getRestPoint(center,radius/2);
	detectRange = 10000;
	
	i = 0;
	last = this.position;
	while (true)
	{
		checkSelfStatus();
		
		if (center == null)
		{
			attack();
			break;
		}
		
		if (com.detectedEgg && !com.detectedWasp)
		{
			if (radar(AlienWasp) != null)
			{
				com.detectedWasp = true;
			}
		}
		
		enemy = search(com.ants,center.position,0,detectRange);
		if (enemy == null && com.detectedWasp)
		{
			enemy = search(AlienWasp,center.position,0,detectRange);
		}
		else if (enemy == null && com.detectedWorm)
		{
			enemy = Radar(AlienWorm);
		}
		
		if (enemy != null)
		{
			if (enemy.category == AlienWorm && topo(enemy.position) < 0)
			{
				Message("Target is underwater, wait for next target");
				continue;
			}
			
			if (com.detectedGraviPlant)
			{
				root = search(GraviPlant,enemy.position,0,com.attackRange);
				if (root != null)
				{
					if (distance2d(this.position,root.position) > com.safeAnt && distance2d(this.position,root.position) < distance2d(this.position,enemy.position))
					{
						left = leftPoint(10);
						right = rightPoint(10);
						left.z = this.position.z;
						right.z = this.position.z;
						if (distance2d(left,enemy.position) < distance2d(right,enemy.position))
						{
							p = left;
						}
						else
						{
							p = right;
						}
						fly(p);
						wait(1);
						continue;
					}
				}
			}
			
			i++;
			moveAndDestroy(enemy);
			if (isStuck(last))
			{
				if (i > 10)
				{
					Message("Avoiding obstacle");
					motor(0,0);
					jet(1);
					wait(1);
					motor(-1,-1);
					wait(1);
					turn(45);
					motor(1,1);
					wait(1);
					i = 0;
					last = this.position;
				}
			}
			else
			{
				i = 0;
				last = this.position;
			}
			
			if (found(PowerCaptor))
			{
				if (distance2d(this.position,center.position) > radius && distance2d(this.position,location(PowerCaptor)) > 50)
				{
					motor(0,0);
					aimAndFire(enemy);
				}
			}
			else
			{
				if (distance2d(this.position,center.position) > radius)
				{
					if (center.category == SpaceShip)
					{
						motor(0,0);
						aimAndFire(enemy);
					}
					else
					{
						fly(center.position);
					}
				}
			}
		}
		else
		{
			break;
		}
	}
	
	landAndRest(start);
	missionComplete();
	errmode(0);
}

public void object::landAttack()
{
	errmode(0);
	SatCom com();
	
	float dir,targetOri;
	float dis;
	float dif;
	float cPitch,angle = 0;
	point p,last,left,right,front,back;
	object o,target,enemies[];
	int i;
	
	i = 0;
	last = this.position;
	aim(0,0);
	while (true)
	{
		if (category != PhazerShooter) checkSelfStatus();
		
		target = radar(com.ants);
		if (target == null) break;
		
		o = radar(Any,0,140,1.5,6);
		if (o == null)
		{
			o = radar(Any,0,90,1.5,3);
		}
		if (o != null && o.category != target.category && distance2d(this.position,target.position) > com.safeAnt)
		{
			turn(direction(o.position));
			motor(-1,-1);
			wait(1);
			turn(45);
			motor(1,1);
			wait(2);
		}
			
		i++;
		crawl(target.position);
		// check if stuck
		if (distance(this.position,last) <= 0.05)
		{
			if (i > 10 || this.pitch > 60)
			{
				if (distance(this.position,target.position) > com.safeAnt)
				{
					Message("Being stuck at current position, searching for path...");
					escapeMountain(this.position,target.position);
					i = 0;
					last = this.position;
					continue;
				}
				else
				{
					Message("Being stuck at current position, try other way");
					motor(-1,-1);
					wait(1);
					turn(60);
					motor(1,1);
					wait(1);
					i = 0;
					last = this.position;
				}
			}
		}
		else
		{
			i = 0;
			last = this.position;
		}
		
		dis = distance2d(this.position,target.position);
		if ((dis <= com.attackRange) || (this.category == PhazerShooter && dis <= com.phazerAttackRange))
		{
			if (this.category != PhazerShooter && !checkLOS(target.position)) continue;
			motor(0,0);
			aimAndFire(target);
		}
	}
	missionComplete();
	errmode(1);
}

public void object::landGuard(object center,float radius)
{
	errmode(0);
	SatCom com();
	
	float detectRange = radius;
	
	float dir,targetOri;
	float dis;
	float dif;
	float cPitch,angle = 0;
	point p,last,left,right,front,back;
	object o,target,enemies[];
	int i;
	
	i = 0;
	last = this.position;
	aim(0,0);
	while (found(com.ants))
	{
		checkSelfStatus();
		
		if (center == null)
		{
			landAttack();
			break;
		}
		
		target = search(com.ants,center.position,0,detectRange);
		
		if (target != null)
		{
			o = radar(Any,0,140,1.5,12);
			if (o == null)
			{
				o = radar(Any,0,90,1.5,5);
			}
			if (o != null && o.category != target.category && o.category != center.category && distance2d(this.position,target.position) > com.safeAnt)
			{
				turn(direction(o.position));
				motor(-1,-1);
				wait(1);
				turn(45);
				motor(1,1);
				wait(2);
			}
			
			i++;
			crawl(target.position);
			// check if stuck
			if (distance(this.position,last) <= 0.05)
			{
				if (i > 10)
				{
					Message("Being stuck at current position, try other way");
					motor(-1,-1);
					wait(1);
					turn(45);
					motor(1,1);
					wait(2);
					i = 0;
					last = this.position;
				}
			}
			else
			{
				i = 0;
				last = this.position;
			}
			
			dis = distance2d(this.position,target.position);
			
			//if (dis <= com.attackRange && -21 < angle && angle < 21)
			if ((dis <= com.attackRange) || (this.category == PhazerShooter && dis <= com.phazerAttackRange))
			{
				if (!checkLOS(target.position))
				{
					left = leftPoint(10);
					right = rightPoint(10);
					left.z = topo(left)+3; // gun is about 3 m  height
					right.z = topo(right)+3;
					
					if (checkLOS(left,target.position))
					{
						crawl(left);
						if (!checkLOS(target.position))
						{
							continue;
						}
					}
					else if (checkLOS(right,target.position))
					{
						crawl(right);
						if (!checkLOS(target.position))
						{
							continue;
						}
					}
					else
					{
						continue;
					}
				}
				motor(0,0);
				aimAndFire(target);
			}
		}
		else
		{
			// if no enenmy in range, follow right side of the guarded object
			front = aheadPoint(center,radius,0);
			right = rightPoint(front,center.position);
			right = space(center.position,15,25,5);
			crawl(right);
		}
	}
	missionComplete();
	errmode(1);
}

public void object::PhazerAim(object target)
{
	errmode(0);
	SatCom com();
	
	float scanRange = com.safeQueen; // scan for targets within this radius
	
	// Platform specific parameters
	float minAngle = -20; // minimum gun elevation relative to platform
	float maxAngle = 45; // maximum gun elevation relative to platform
	float weaponHeight = 2; // height of weapon above platform
	float weaponOffset = 2; // weapon is this amount in front of platform
	float maxTurnRate = 54; // maximum turn rate
	
	// Ballistic parameters
	float v0 = 50; // muzzle velocity (m / s)
	float g = 50; // gravitation (m / s^2)
	float bc = v0 * v0 / g; // ballistic constant (max range at equal height)
	
	// Variables to track target (cylindrical coordinates)
	float bearing, range, height, time, dis;
	float deltaBearing, deltaRange, deltaHeight, deltaTime;
	
	// Old variables
	float oldBearing;
	float oldRange;
	float oldHeight;
	float oldTime;
	
	// Variables needed for target solution
	float rt,zt;
	float t;
	float D;
	float it;
	float azimuth;
	float elevation;
	float turnRate;
	float motorOutput;
	float cosAngle;
	
	// Variables needed for slope correction
	float pitchAz;
	float rollAz;
	float a;
	float b;
	float c;
	float d;
	float x;
	float corr;
	
	float fireTime;
	
	object current;
	
	if (target != null && target.category != AlienEgg)
	{
		// Initialize the old variables
		oldBearing = orientation + direction(target.position);
		oldRange = distance2d(position, target.position);
		oldHeight = target.position.z - position.z;
		oldTime = abstime();
		
		it = sqrt(2) * oldRange / v0; // initial estimate for intercept time
		fireTime = abstime() + 0.2; // don't fire for 0.5 seconds (first track target)
		
		while (true) 
		{
			current = radar(com.enemies,0,360,0,scanRange);
			if (target == null || current == null || target != current)
			{
				break;
			}
			
			// Collect data
			bearing = this.orientation + direction(target.position);
			range = distance2d(this.position, target.position);
			height = target.position.z - this.position.z;
			time = abstime();
			
			// Calculate differences
			deltaBearing = bearing - oldBearing;
			if (deltaBearing < -180)
			{
				deltaBearing += 360;
			}
			if (deltaBearing > 180)
			{
				deltaBearing -= 360;
			}
			deltaRange = range - oldRange;
			deltaHeight = height - oldHeight;
			deltaTime = time - oldTime;
			if (deltaTime == 0.0)
			{
				deltaTime = 0.001;
			}
			
			// Save data for next pass
			oldBearing = bearing;
			oldRange = range;
			oldHeight = height;
			oldTime = time;
			
			// Extrapolate target motion to interception point
			t = it / deltaTime; // time factor
			azimuth = bearing + t * deltaBearing - orientation; // intercept azimuth
			if (azimuth < -180)
			{
				azimuth += 360; // azimuth correction (pole passage)
			}
			if (azimuth > 180)
			{
				azimuth -= 360;
			}
			zt = height + t * deltaHeight - cos(pitch) * cos(roll) * weaponHeight; // intercept height
			rt = range + t * deltaRange - weaponOffset * cos(azimuth) * cos(pitch); // intercept range
			if (rt < 0.001)
			{
				rt = 0.001;
			}
			
			// Calculate weapon elevation
			D = bc * (bc - 2 * zt) / (rt * rt) - 1; // discriminant
			if (D < 0)
			{
				elevation = atan(bc / rt); // target out of range
			}
			else
			{
				elevation = atan(bc / rt - sqrt(D)); // target in range
			}
			
			cosAngle = cos(elevation);
			if (abs(cosAngle) < 0.001)
			{
				cosAngle = 0.001;
			}
			
			it = rt / (v0 * cosAngle); // intercept time (estimate for next pass)
			if (it < 0.05)
			{
				it = 0.05;
			}
			
			// Slope-correction
			pitchAz = pitch * cos(azimuth) - roll * sin(azimuth); // pitch at target azimuth
			rollAz = roll * cos(azimuth) + pitch * sin(azimuth); // roll at target azimuth
			
			// Solve slope-target spherical triangle
			b = elevation - pitchAz; // relative elevation at target azimuth
			x = sin(b) * cos(rollAz);
			if (x < -1)
			{
				x = -1;
			}
			else if (x > 1)
			{
				x = 1;
			}
			a = asin(x); // new gun elevation
			
			cosAngle = cos(a);
			if (abs(cosAngle) < 0.001)
			{
				cosAngle = 0.001;
			}
			
			x = cos(b) / cosAngle;
			if (x < -1)
			{
				x = -1;
			}
			else if (x > 1)
			{
				x = 1;
			}
			c = acos(x);
			
			if (b < 0) 
			{
				c = -c; // intermediate variable
			}
			
			x = sin(c) * sin(rollAz);
			if (x < -1)
			{
				x = -1;
			}
			else if (x > 1)
			{
				x = 1;
			}
			d = asin(x); // intermediate variable
			
			cosAngle = cos(d);
			if (abs(cosAngle) < 0.001)
			{
				cosAngle = 0.001;
			}
			
			x = cos(c) / cosAngle;
			if (x < -1)
			{
				x = -1;
			}
			else if (x > 1)
			{
				x = 1;
			}
			corr = -acos(x);
			
			if (d < 0)
			{
				corr = -corr; // azimuth correction
			}
			
			azimuth += corr; // apply azimuthal correction
			
			// Point the weapon in the right direction
			if (a < minAngle)
			{
				aim(minAngle);
			}
			else if (a > maxAngle)
			{
				aim(maxAngle);
			}
			else
			{
				aim(a); // weapon elevation
			}
			
			turnRate = (deltaBearing + azimuth / 5) / deltaTime; // rotate with target
			motorOutput = 0.5 * turnRate / maxTurnRate; // calculate motor output
			if (motorOutput > 1)
			{
				motorOutput = 1;
			}
			if (motorOutput < -1)
			{
				motorOutput = -1;
			}
			motor(-motorOutput, motorOutput); // apply turn rate
			
			// Fire if target is within weapon envelope
			if (D >= 0 && a > minAngle - 2 && a < maxAngle + 2 && azimuth > -2 && azimuth < 2 && fireTime < abstime())
			{
				if (target != null && !target.dead)
				{
					fire(0.2);
					fireTime = abstime() + it + 0.1; // wait until round hit (or not)
					Message("Firing at range " + dis + " m.");
				}
			}
		}
	}
	errmode(1);
}

public void object::LandAim(object target)
{
	errmode(0);
	SatCom com();
	
	float scanRange = com.attackRange; // scan for targets within this radius
	
	// Platform specific parameters
	float minAngle = -20; // minimum gun elevation relative to platform
	float maxAngle = 20; // maximum gun elevation relative to platform
	float weaponHeight = (this.category == LeggedOrgaShooter ? 2.0 : 1.5); // height of weapon above platform
	float weaponOffset = (this.category == LeggedOrgaShooter ? 2.0 : 1.5); // weapon is this amount in front of platform
	float maxTurnRate = 54; // maximum turn rate
	
	// Ballistic parameters
	float v0 = 50; // muzzle velocity (m / s)
	float g = 50; // gravitation (m / s^2)
	float bc = v0 * v0 / g; // ballistic constant (max range at equal height)
	
	// Variables to track target (cylindrical coordinates)
	float bearing, range, height, time, dis;
	float deltaBearing, deltaRange, deltaHeight, deltaTime;
	
	// Old variables
	float oldBearing;
	float oldRange;
	float oldHeight;
	float oldTime;
	
	// Variables needed for target solution
	float rt,zt;
	float t;
	float D;
	float it;
	float azimuth;
	float elevation;
	float turnRate;
	float motorOutput;
	float cosAngle;
	
	// Variables needed for slope correction
	float pitchAz;
	float rollAz;
	float a;
	float b;
	float c;
	float d;
	float x;
	float corr;
	
	float fireTime;
	
	object current;
	
	if (target == null || target.dead) return;
	
	// Initialize the old variables
	oldBearing = this.orientation + direction(target.position);
	oldRange = distance2d(this.position, target.position);
	oldHeight = target.position.z - this.position.z;
	oldTime = abstime();
	
	it = oldRange / v0; // initial estimate for intercept time
	fireTime = abstime() + 0.2; // don't fire for 0.5 seconds (first track target)
	
	while (true)
	{
		// check if other enemy came closer than target
		current = radar(com.ants,0,360,0,com.attackRange);
		if (target == null || current == null || current != target)
		{
			return;
		}
		
		// Collect data
		bearing = this.orientation + direction(target.position);
		range = distance2d(this.position, target.position);
		height = target.position.z - this.position.z;
		time = abstime();
		
		// check if target run away
		if (range > com.attackRange) return;
		
		// Calculate differences
		deltaBearing = bearing - oldBearing;
		if (deltaBearing < -180)
		{
			deltaBearing += 360;
		}
		if (deltaBearing > 180)
		{
			deltaBearing -= 360;
		}
		deltaRange = range - oldRange;
		deltaHeight = height - oldHeight;
		deltaTime = time - oldTime;
		if (deltaTime < 0.001)
		{
			deltaTime = 0.001;
		}
		
		// Save data for next pass
		oldBearing = bearing;
		oldRange = range;
		oldHeight = height;
		oldTime = time;
		
		// Extrapolate target motion to interception point
		t = it / deltaTime; // time factor
		azimuth = bearing + t * deltaBearing - orientation; // intercept azimuth
		if (azimuth < -180)
		{
			azimuth += 360; // azimuth correction (pole passage)
		}
		if (azimuth > 180)
		{
			azimuth -= 360;
		}
		//zt = height + t * deltaHeight - cos(pitch) * cos(roll) * weaponHeight; // intercept height
		//rt = range + t * deltaRange - weaponOffset * cos(azimuth) * cos(pitch); // intercept range
		zt = height + t * deltaHeight - (cos(pitch) * cos(roll) * weaponHeight + sin(pitch) * weaponOffset);   // weaponHeight + cross-term
		rt = range + t * deltaRange - (weaponOffset * cos(azimuth) * cos(pitch) - sin(pitch) * weaponHeight);  // weaponOffset + cross-term
		if (rt < 0.001)
		{
			rt = 0.001;
		}
		
		// Calculate weapon elevation
		elevation = atan2(zt,rt);
		
		cosAngle = cos(elevation);
		if (abs(cosAngle) < 0.001)
		{
			cosAngle = 0.001;
		}
		
		it = sqrt(rt*rt + zt*zt) / v0; // intercept time (estimate for next pass)
		if (it < 0.05)
		{
			it = 0.05;
		}
		
		// Slope-correction
		pitchAz = pitch * cos(azimuth) - roll * sin(azimuth); // pitch at target azimuth
		rollAz = roll * cos(azimuth) + pitch * sin(azimuth); // roll at target azimuth
		
		// Solve slope-target spherical triangle
		b = elevation - pitchAz; // relative elevation at target azimuth
		x = sin(b) * cos(rollAz);
		if (x < -1)
		{
			x = -1;
		}
		else if (x > 1)
		{
			x = 1;
		}
		a = asin(x); // new gun elevation
		
		cosAngle = cos(a);
		if (abs(cosAngle) < 0.001)
		{
			cosAngle = 0.001;
		}
		
		x = cos(b) / cosAngle;
		if (x < -1)
		{
			x = -1;
		}
		else if (x > 1)
		{
			x = 1;
		}
		c = acos(x);
		
		if (b < 0) 
		{
			c = -c; // intermediate variable
		}
		
		x = sin(c) * sin(rollAz);
		if (x < -1)
		{
			x = -1;
		}
		else if (x > 1)
		{
			x = 1;
		}
		d = asin(x); // intermediate variable
		
		cosAngle = cos(d);
		if (abs(cosAngle) < 0.001)
		{
			cosAngle = 0.001;
		}
		
		x = cos(c) / cosAngle;
		if (x < -1)
		{
			x = -1;
		}
		else if (x > 1)
		{
			x = 1;
		}
		corr = -acos(x);
		
		if (d < 0)
		{
			corr = -corr; // azimuth correction
		}
		
		azimuth += corr; // apply azimuthal correction
		
		// Point the weapon in the right direction
		if (a < minAngle)
		{
			aim(minAngle);
		}
		else if (a > maxAngle)
		{
			aim(maxAngle);
		}
		else
		{
			aim(a); // weapon elevation
		}
		
		turnRate = (deltaBearing + azimuth / 5) / deltaTime; // rotate with target
		motorOutput = 0.5 * turnRate / maxTurnRate; // calculate motor output
		if (motorOutput > 1)
		{
			motorOutput = 1;
		}
		if (motorOutput < -1)
		{
			motorOutput = -1;
		}
		motor(-motorOutput, motorOutput); // apply turn rate
		
		// Fire if target is within weapon envelope
		if (a > minAngle && a < maxAngle && azimuth > -2 && azimuth < 2 && fireTime < abstime())
		{
			if (target != null && !target.dead)
			{
				fire(0.2);
				fireTime = abstime() + it + 0.1; // wait until round hit (or not)
				Message("Fired with advance aim");
				//Message("Firing at range " + dis + " m.");
			}
		}
		else if (range <= 15)
		{
			aimat(target.position);
			if (target != null && !target.dead)
			{
				fire(0.2);
				fireTime = abstime() + it + 0.1; // wait until round hit (or not)
				Message("Fired with normal aim");
				//Message("Firing at range " + dis + " m.");
			}
		}		
	}
	errmode(1);
}

public void object::AirAim(object target)
{
	SatCom com();
	
	float scanRange = com.safeAnt; // scan for targets within this radius
	float angle;
	int i;
	object current;
	
	if (target == null || target.dead || distance2d(this.position,target.position) > com.attackRange)
	{
		return;
	}
	
	// Stabilize altitude
	i = 0;
	do
	{
		i++;
		
		current = radar(com.enemies,0,360,0,scanRange);
		if (target == null || current == null || target != current)
		{
			jet(0);
			return;
		}
		
		angle = -atan2(this.position.z - target.position.z,distance2d(this.position,target.position)) - this.pitch;
		
		if (angle > 18)
		{
			jet(0.5);
		}
		else if (angle < -18)
		{
			jet(-0.5);
		}
		wait(0.02);
	}
	while ((angle < -18 || angle > 18) && i < 100);
	
	jet(0);
	
	if (target != null && !target.dead)
	{
		aimat(target.position);
		fire(0.05);
		wait(0.1);
	}
}

public void object::aimat(point p)
{
	turn(direction(p));
	float dist=distance2d(p,this.position);
	float height=this.position.z-p.z;
	float ipitch=atan2(height,dist);
	ipitch+=this.pitch; //compensate
	float iangle=direction(p);
	//here we rotate ipitch and iangle by roll to compensate for that part of the scheme
	float aimpitch=ipitch*cos(roll)-iangle*sin(roll);
	float aimangle=iangle*cos(roll)+ipitch*sin(roll);
	aim(-aimpitch,-aimangle);
}

public point[] object::searchEscapeMountainPath(point botPoint, point target)
{
	SatCom com();
	int totalNodes = com.totalNodes;
	
	float groundLevel = topo(com.spaceShip.position) - 7;
	float safeFlyingHeight = groundLevel + 10.0;
	float maxOpenHeight = (target.z + 3 > groundLevel + 3 ? target.z + 3 : groundLevel + 3);
	
	int startIndex = getNodeIndex(botPoint);
	int targetIndex = getNodeIndex(target);
	
	point startPoint; startPoint.x = getNodeX(startIndex); startPoint.y = getNodeY(startIndex); startPoint.z = getNodeZ(startIndex);
	plantFlag(startPoint, YellowFlag);
	point targetPoint; targetPoint.x = getNodeX(targetIndex); targetPoint.y = getNodeY(targetIndex); targetPoint.z = getNodeZ(targetIndex);
	plantFlag(targetPoint, GreenFlag);
	
	if (startIndex == targetIndex)
	{
		point shortPath[2];
		shortPath[0] = botPoint; shortPath[0].z = safeFlyingHeight;
		shortPath[1] = target;   shortPath[1].z = safeFlyingHeight;
		return shortPath;
	}
	
	// ---------- SIMPLE A* DATA ----------
	int visited[totalNodes];
	int parent[totalNodes];
	int gCost[totalNodes];
	int fCost[totalNodes];
	int openList[totalNodes];
	int openSize = 0;
	int inOpen[totalNodes];
	
	for (int i = 0; i < totalNodes; i++)
	{
		visited[i] = 0;
		parent[i] = -1;
		gCost[i] = 999999;
		fCost[i] = 999999;
		inOpen[i] = 0;
	}
	
	gCost[startIndex] = 0;
	fCost[startIndex] = abs(getNodeX(startIndex) - targetPoint.x) + abs(getNodeY(startIndex) - targetPoint.y); // Manhattan
	openList[openSize] = startIndex;
	openSize = openSize + 1;
	inOpen[startIndex] = 1;
	
	int found = 0;
	int meetNode = -1;
	int nodesExplored = 0;
	
	// ---------- SIMPLE LOOP ----------
	while (found == 0 && openSize > 0)
	{
		// Find best node
		int bestIdx = -1;
		int bestF = 999999;
		int bestOpenIdx = -1;
		
		for (int i = 0; i < openSize; i++)
		{
			int idx = openList[i];
			if (fCost[idx] < bestF)
			{
				bestF = fCost[idx];
				bestIdx = idx;
				bestOpenIdx = i;
			}
		}
		
		if (bestIdx == -1) break;
		
		// Remove from open
		openList[bestOpenIdx] = openList[openSize - 1];
		openSize = openSize - 1;
		inOpen[bestIdx] = 0;
		
		int current = bestIdx;
		visited[current] = 1;
		nodesExplored = nodesExplored + 1;
		
		if (current == targetIndex)
		{
			meetNode = current;
			found = 1;
			break;
		}
		
		// Expand 8 neighbors
		for (int d = 0; d < 8; d++)
		{
			int next = getNeighborIndex(current, d);
			if (next == -1) continue;
			if (getNodeZ(next) > maxOpenHeight) continue;
			if (visited[next] == 1) continue;
			
			int tentativeG = gCost[current] + 1;
			
			if (tentativeG < gCost[next])
			{
				gCost[next] = tentativeG;
				parent[next] = current;
				fCost[next] = tentativeG + abs(getNodeX(next) - targetPoint.x) + abs(getNodeY(next) - targetPoint.y);
				
				if (inOpen[next] == 0)
				{
					openList[openSize] = next;
					openSize = openSize + 1;
					inOpen[next] = 1;
				}
			}
		}
	}
	
	// ---------- RECONSTRUCT ----------
	if (found == 0 || meetNode == -1)
	{
		Message("A*: No path, direct");
		point directPath[2];
		directPath[0] = botPoint; directPath[0].z = safeFlyingHeight;
		directPath[1] = target;   directPath[1].z = (target.z <= 0.0) ? safeFlyingHeight : target.z + 10.0;
		return directPath;
	}
	
	int tempPath[totalNodes];
	int pathLen = 0;
	int current = meetNode;
	while (current != -1 && pathLen < totalNodes)
	{
		tempPath[pathLen] = current;
		pathLen = pathLen + 1;
		current = parent[current];
	}
	
	point result[pathLen];
	for (int i = 0; i < pathLen; i = i + 1)
	{
		int idx = tempPath[pathLen - 1 - i];
		result[i] = getNodePoint(idx);
		plantFlag(result[i], Target2);
	}
	
	Message("A* explored " + nodesExplored + " nodes, path: " + pathLen);
	return result;
}

public void object::escapeMountain(point botPoint, point target)
{
	SatCom com();
	
	float z = this.position.z;
	float ground = topo(com.spaceShip.position) - 7;
	object enemy;
	
	if (this.category == LeggedShooter || this.category == LeggedOrgaShooter)
	{
		point p = searchSafeLZ(this.position);
		go(p);
	}
	gotoSafeLZ();
	jet(-0.01);
	turn(direction(target));
	motor(0,0);
	float t = abstime();
	float dir;
	float dis;
	Message("Searching for path...");
	point pathPoints[] = searchEscapeMountainPath(this.position, target);
	int pathLength = sizeof(pathPoints);
	int i;
	point p,next;
	if (pathLength < 3)
	{
		gotoSafeLZ();
		return;
	}
	Message("Path found in " + (abstime()-t) + " second(s), switch to guided mode");
	for (i = 1; i < pathLength; i++)
	{
		p = pathPoints[i];
		if (i < pathLength - 1)
		{
			next = pathPoints[i+1];
		}
		else
		{
			next = p;
		}
		turn(direction(p));
		dis = distance2d(this.position,target);
		if (checkLOS(target) && dis > com.safeAnt)
		{
			Message("Line of sight clear, switch to combat mode");
			return;
		}
		while (distance2d(this.position,p) > 5 && distance2d(this.position,p) < distance2d(this.position,next))
		{
			enemy = radar(com.ants,0,360,0,com.attackRange);
			if (enemy != null)
			{
				if (checkLOS(enemy.position))
				{
					checkEnemyWhenInLoop();
					return;
				}
			}
			
			if (this.temperature > com.temperatureThreshold)
			{
				Message("Engine temperature is too high, goto safe landing zone");
				gotoSafeLZ();
				if (pathLength < 20)
				{
					return;
				}
			}
			
			jet(1);
			dir = direction(p);
			motorPower(dir);
			if ((this.category == LeggedShooter || this.category == LeggedOrgaShooter) && this.pitch > 60)
			{
				Message("Being stuck at current position, try other way");
				motor(-1,-1);
				wait(1);
				turn(45);
				motor(1,1);
				wait(2);
			}
		}
	}
}
