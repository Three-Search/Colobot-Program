public void object::plantFlag(point p, int c)
{
	SatCom com();
	point f;
	
	if (com.plantFlag)
	{
		f.x = p.x;
		f.y = p.y;
		f.z = topo(p);
		produce(f,0,c);
	}
}

public void object::crawl2p(point p)
{
	turn(direction(p));
	while (distance2d(this.position,p) > 1)
	{
		crawl(p);
	}
}

public void object::crawl(point p)
{
	float dir;
	point sensor;
	
	for (int i = 30; i > 0; i--)
	{
		sensor = aheadPoint(i,i-60);
		if (topo(sensor) < 0)
		{
			motor(-1,-1);
			wait(0.2);
			dir = 60-i;
			motor(1 - dir/180,1 + dir/180);
			wait(0.2);
			return;
		}
	}
	
	dir = direction(p);
	motor(1 - dir/180,1 + dir/180);
	
	cacheGrid(p);
}

public void object::jetPower(point p)
{
	float dis = distance(this.position,p);
	float dif = p.z-this.position.z;
	float ang = asin(dif/dis);
	if (dis <= 60)
	{
		jet(1-(ang/-18)); // thrust until 18 degrees above target
	}
	else if (60 < dis && dis < 120)
	{
		jet(1-(ang/-16)); // thrust until 16 degrees above target
	}
	else
	{
		jet(1-(ang/-12)); // thrust until 12 degrees above target
	}
}

public void object::motorPower(float direction)
{
	float dir,speed,turn;
	dir = direction;
	if (abs(dir) < 5) dir = 0;
	speed = 1 - abs(dir)/180;
	turn = dir / 180;
	motor(speed - turn, speed + turn);
}

public void object::cacheGrid(point p)
{
	SatCom com();
	
	point m = mid(this.position,p);
	int idx = getNodeIndex(m);
	if (com.gridZ[idx] < 999) return; // already cached
	
	Message("Caching gridZ "+com.cachedNodes);
	float z = getNodeZ(idx);
	for (int d = 0; d < 8; d++)
	{
		int nextIndex = getNeighborIndex(idx, d);
		if (nextIndex == -1) continue;  // Out of bounds
		z = getNodeZ(nextIndex);
	}
}

public void object::fly(point p)
{
	SatCom com();
	
	float dir; // direction of point p from bot
	float dis; // distance of point p from bot
	float dif; // difference in altitude of point p & bot (relative to sea-level)
	float ang; // flying angle must be -20 degrees favorable
	
	float j;
	float speed,turn;
	point hit,left,right;
	object root,o;
	
	if (this.altitude < 0.2)
	{
		jet(0.5);
	}
	
	if (com.detectedGraviPlant)
	{
		root = radar(GraviPlant,0,360,0,com.safeAnt);
		if (root != null)
		{
			dir = direction(root.position);
			if (distance2d(this.position,root.position) <= com.safeRoot && -60 < dir && dir < 60)
			{
				checkEnemyWhenInLoop();
				dir = direction(root.position);
				if (dir >= 0)
				{
					dir += 180;
				}
				else
				{
					dir -= 180;
				}
				turn(dir);
				Message("Too close to GraviPlant! Retreating...");
				while (distance2d(this.position,root.position) <= com.safeRoot)
				{
					jet(0.5);
					motor(0.8,0.8);
					if (this.temperature > com.temperatureThreshold)
					{
						gotoSafeLZ();
						return;
					}
				}
				return;
			}
			else
			{
				motorPower(direction(p));
				return;
			}
		}
	}
	
	o = radar(SpaceShip,0,30,com.safeRoot,com.safeAnt);
	if (o != null)
	{
		dir = 25;
		motorPower(dir);
		return;
	}
	
	if (distance2d(this.position,com.spaceShip.position) < 2.5)
	{
		dir = 25;
		motor(-1,-1);
		wait(1);
		motorPower(dir);
		return;
	}
	
	o = radar(com.ALL_BOTS,0,30,com.safeRoot,com.safeAnt);
	if (o != null)
	{
		dir = 25;
		motorPower(dir);
		return;
	}
	
	jetPower(p);
	motorPower(direction(p));
	
	cacheGrid(p);
}

public void object::fly2p(point p)
{
	SatCom com();
	
	float dir; // direction of point p from bot
	float dis; // distance of point p from bot
	float dis2d;
	float dif; // difference in altitude of point p & bot (relative to sea-level)
	float ang; // flying angle must be -20 degrees favorable
	int i;
	
	if (p.z < 0)
	{
		Message("Cannot fly to underwater point");
		return;
	}
	turn(direction(p));
	dis2d = distance2d(this.position,p);
	if (dis2d <= 5.5)
	{
		com.returnMessage = "Target is within 5.5m, moving forward";
		i = 0;
		while (dis2d > 1 && i < 20)
		{
			turn(direction(p));
			motor(0.2,0.2);
			dis2d = distance2d(this.position,p);
			i++;
		}
		i = 0;
		while (this.altitude > 0 && i < 20)
		{
			jet(-0.8);
			i++;
		}
		return;
	}
	com.returnMessage = "Flying to target point...";
	while (dis2d > 5.5 && this.temperature < 0.95)
	{
		fly(p);
		dis2d = distance2d(this.position,p);
	}
	com.returnMessage = "Landing on target point...";
	i = 0;
	motor(0,0);
	while (this.altitude > 0.2 && i < 100)
	{
		if (3 < this.altitude)
		{
			jet(-1);
		}
		else if (1 < this.altitude && this.altitude <= 3)
		{
			jet(-0.8);
		}
		else
		{
			jet(-0.1);
		}
		if (this.temperature == 0) // if stuck on tree, temperature will reduce to 0
		{
			break;
		}
		i++;
	}
}

public void object::fly(object o)
{
	SatCom com();
	point p,last;
	com.returnMessage = category+": fly(object o) start";
	com.returnCode = 1;
	int i;
	if (o == null)
	{
		com.returnMessage = category+": Object null, could not fly to object";
		com.returnCode = 1;
		return;
	}
	
	p = o.position;
	turn(direction(p));
	jet(1);
	wait(0.2);
	i = 0;
	last = this.position;
	while (o != null && distance2d(this.position,p) > 5 && distance2d(this.position,o.position) > 5)
	{
		if (this.temperature > com.temperatureThreshold)
		{
			gotoSafeLZ();
		}
		
		i++;
		fly(p);
		if (isStuck(last))
		{
			if (i > 10)
			{
				Message("Avoiding obstacle");
				motor(0,0);
				jet(1);
				wait(1);
				motor(-1,-1);
				wait(1);
				turn(45);
				motor(1,1);
				wait(1);
				i = 0;
				last = this.position;
			}
		}
		else
		{
			i = 0;
			last = this.position;
		}
		if (this.altitude < 2)
		{
			break;
		}
	}
	
	motor(0,0);
	while (this.altitude > 0)
	{
		jet(-0.8);
	}
	com.returnCode = 0;
}

