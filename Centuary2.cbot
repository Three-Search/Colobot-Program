extern void object::Centuary2()
{
	SatCom com();
	
	errmode(0);
	
	object target,o;
	object[] items = radarall(GoalArea);
	
	for (int i = 0; i < sizeof(items); ++i)
	{
		o = items[i];
		go(o);
		target = radar(TargetBot,0,360,0,com.attackRange);
		while (target != null)
		{
			aimat(target.position);
			fire(0.05);
			wait(0.5);
			target = radar(TargetBot,0,360,0,com.attackRange);
		}
	}
	go(SpaceShip);
	missionComplete();
	takeoff();
}
